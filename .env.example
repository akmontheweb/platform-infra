# =============================================================================
# platform-infra — Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values before running `make up`.
# =============================================================================

# ── Platform PostgreSQL (superuser — used by Terraform to create per-project DBs)
PLATFORM_PG_SUPERUSER=platform
PLATFORM_PG_SUPERPASSWORD=<CHANGE_ME>
PLATFORM_PG_PORT=5433          # use 5432 if Cue's private postgres is decommissioned

# ── Platform Keycloak database
PLATFORM_KC_DB_USER=keycloak
PLATFORM_KC_DB_PASSWORD=<CHANGE_ME>

# ── Platform Keycloak admin
PLATFORM_KC_ADMIN_USER=admin
PLATFORM_KC_ADMIN_PASSWORD=<CHANGE_ME>
PLATFORM_HOSTNAME=10.0.0.95    # server IP or domain (for KC_HOSTNAME)
PLATFORM_KC_PORT=8081          # use 8080 if Cue's private keycloak is decommissioned

# ── Platform MinIO root credentials
PLATFORM_MINIO_ROOT_USER=platform
PLATFORM_MINIO_ROOT_PASSWORD=<CHANGE_ME>
PLATFORM_MINIO_PORT=9002       # use 9000 if Cue's private minio is decommissioned
PLATFORM_MINIO_CONSOLE_PORT=9003

# ── Platform Redis
PLATFORM_REDIS_PORT=6380       # use 6379 if Cue's private redis is decommissioned

# ── LiteLLM
# Master key enables virtual key management (one key per project)
# Generate: python -c "import secrets; print('sk-' + secrets.token_hex(32))"
LITELLM_MASTER_KEY=<CHANGE_ME>
PLATFORM_LITELLM_PORT=4001     # use 4000 if Cue's private litellm is decommissioned

# LLM model assignments (shared across all projects via model aliases)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=<CHANGE_ME>
OLLAMA_BASE_URL=http://host.docker.internal:11434
LLM_FAST_MODEL=openai/gpt-4o-mini
LLM_BALANCED_MODEL=openai/gpt-4o-mini
LLM_EMBEDDING_MODEL=openai/text-embedding-3-small
VOICE_TRANSCRIPT_MODEL=openai/whisper-1
LLM_VISION_MODEL=openai/gpt-4o-mini

# ── Observability ports
PLATFORM_OTEL_GRPC_PORT=4319   # use 4317 after Cue's private stack decommissioned
PLATFORM_OTEL_HTTP_PORT=4320
PLATFORM_OTEL_METRICS_PORT=8890
PLATFORM_JAEGER_UI_PORT=16687
PLATFORM_PROMETHEUS_PORT=9091
PLATFORM_GRAFANA_PORT=3002
PLATFORM_GRAFANA_ADMIN_PASSWORD=<CHANGE_ME>

# ── Caddy (only needed for production TLS routing)
DOMAIN=yourdomain.com
CADDY_OBS_USER=admin
# Generate: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'yourpassword'
CADDY_OBS_PASSWORD_HASH=<CHANGE_ME>
